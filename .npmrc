# Minimum package age security - only allow packages published at least 72 hours ago
# This helps protect against typosquatting and supply chain attacks
minimum-package-age=72h

# Enable strict peer dependencies
strict-peer-dependencies=true

# Save exact versions for production dependencies
save-exact=true

# Use hard links for faster installs
package-import-method=hardlink

# Prefer offline installs when possible
prefer-offline=true

# Ignore scripts for faster installs (optional, uncomment if needed)
# ignore-scripts=true

# Enable modern resolution
resolution-mode=highest

# Only allow https registries
https-only=true
